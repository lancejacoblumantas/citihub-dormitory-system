PORT=4000
FRONTEND_ORIGIN=http://127.0.0.1:5500
FIREBASE_PROJECT_ID=citihub-example
PAYMONGO_SECRET_KEY=your_paymongo_secret
RESEND_API_KEY=your_resend_api_key

# Use one of the Firebase Admin options below.
# Option 1: path to a service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\serviceAccountKey.json

# Option 2: inline JSON string for the service account
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
